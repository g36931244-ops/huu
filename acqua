<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>L'Importanza dell'Acqua</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #020d18;
  --surface: #061828;
  --card: #0a2235;
  --border: rgba(0,180,255,0.12);
  --accent: #00b4ff;
  --accent2: #00e5c0;
  --accent3: #0066ff;
  --text: #d6eef8;
  --muted: #5a8ba8;
  --danger: #ff4e50;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'IBM Plex Sans', sans-serif;
  overflow-x: hidden;
}

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 4rem 2rem 2rem;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,100,200,0.25) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 80%, rgba(0,229,192,0.08) 0%, transparent 60%);
}

.water-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,180,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,180,255,0.04) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: gridShift 20s linear infinite;
}

@keyframes gridShift {
  0% { transform: translateY(0); }
  100% { transform: translateY(40px); }
}

.molecule {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
  animation: float 8s ease-in-out infinite;
}

.molecule:nth-child(1) { width:300px; height:300px; background: radial-gradient(var(--accent), transparent); top:-100px; left:-80px; animation-delay:0s; }
.molecule:nth-child(2) { width:200px; height:200px; background: radial-gradient(var(--accent2), transparent); bottom:50px; right:-60px; animation-delay:-3s; }
.molecule:nth-child(3) { width:150px; height:150px; background: radial-gradient(var(--accent3), transparent); top:40%; left:10%; animation-delay:-5s; }

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20px) scale(1.05); }
}

.hero-label {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.2em;
  color: var(--accent);
  text-transform: uppercase;
  border: 1px solid var(--border);
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 1.5rem;
  backdrop-filter: blur(8px);
  background: rgba(0,180,255,0.05);
  position: relative; z-index: 1;
}

.hero h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(4rem, 12vw, 9rem);
  line-height: 0.9;
  letter-spacing: 0.02em;
  color: #fff;
  position: relative; z-index: 1;
  text-shadow: 0 0 80px rgba(0,180,255,0.3);
}

.hero h1 span {
  display: block;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-sub {
  font-size: 1.05rem;
  color: var(--muted);
  max-width: 520px;
  line-height: 1.7;
  margin-top: 1.5rem;
  position: relative; z-index: 1;
}

.hero-stats {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 3rem;
  position: relative; z-index: 1;
}

.hero-stat {
  text-align: center;
  border: 1px solid var(--border);
  padding: 1rem 1.5rem;
  border-radius: 12px;
  background: rgba(6,24,40,0.7);
  backdrop-filter: blur(12px);
  min-width: 130px;
}

.hero-stat .num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.5rem;
  line-height: 1;
  color: var(--accent);
}

.hero-stat .unit {
  font-size: 0.75rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 4px;
}

/* ── SECTIONS ── */
.section {
  padding: 5rem 2rem;
  max-width: 1100px;
  margin: 0 auto;
}

.section-tag {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  color: var(--accent2);
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  letter-spacing: 0.02em;
  color: #fff;
  margin-bottom: 2.5rem;
  line-height: 1;
}

/* ── FUNZIONI CARDS ── */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}

.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.5rem;
  transition: transform 0.2s, border-color 0.2s;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  opacity: 0;
  transition: opacity 0.2s;
}

.card:hover { transform: translateY(-4px); border-color: rgba(0,180,255,0.3); }
.card:hover::before { opacity: 1; }

.card-icon { font-size: 2rem; margin-bottom: 0.75rem; }
.card-title { font-weight: 600; font-size: 0.95rem; color: #fff; margin-bottom: 0.5rem; }
.card-text { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

/* ── DISTRIBUZIONE BAR CHART ── */
.divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 0;
}

.chart-section {
  background: var(--surface);
  padding: 5rem 2rem;
}

.chart-inner {
  max-width: 1100px;
  margin: 0 auto;
}

.bar-chart { display: flex; flex-direction: column; gap: 16px; margin-top: 1rem; }

.bar-row {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
}

.bar-label {
  font-size: 0.8rem;
  color: var(--text);
  width: 140px;
  flex-shrink: 0;
  text-align: right;
  transition: color 0.2s;
}

.bar-row:hover .bar-label { color: var(--accent); }

.bar-track {
  flex: 1;
  height: 34px;
  background: rgba(0,180,255,0.06);
  border-radius: 8px;
  overflow: visible;
  position: relative;
}

.bar-fill {
  height: 100%;
  border-radius: 8px;
  display: flex;
  align-items: center;
  padding-left: 12px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem;
  font-weight: 500;
  white-space: nowrap;
  width: 0;
  transition: width 1.2s cubic-bezier(0.22,1,0.36,1), filter 0.2s, transform 0.2s;
  position: relative;
  overflow: hidden;
}

.bar-fill.animated { width: var(--target-width) !important; }

.bar-row:hover .bar-fill {
  filter: brightness(1.25);
  transform: scaleY(1.08);
}

.bar-tooltip {
  position: absolute;
  top: -44px;
  left: 50%;
  transform: translateX(-50%);
  background: #0a2235;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 5px 12px;
  font-size: 0.75rem;
  font-family: 'IBM Plex Mono', monospace;
  color: var(--text);
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  z-index: 10;
}

.bar-row:hover .bar-tooltip { opacity: 1; }

.bar-val {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.8rem;
  color: var(--muted);
  width: 55px;
  flex-shrink: 0;
  transition: color 0.2s;
}

.bar-row:hover .bar-val { color: var(--accent2); }

/* ── CICLO ACQUA ── */
.ciclo-section {
  background: var(--bg);
  padding: 5rem 2rem;
}
.ciclo-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.ciclo-canvas {
  width: 100%;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: #030e1c;
  position: relative;
  overflow: hidden;
  height: 420px;
}
.ciclo-canvas canvas {
  width: 100%;
  height: 100%;
  display: block;
}
.ciclo-steps {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 1.5rem;
  justify-content: center;
}
.ciclo-btn {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  padding: 7px 16px;
  border-radius: 30px;
  border: 1px solid var(--border);
  background: var(--card);
  color: var(--muted);
  cursor: pointer;
  transition: all 0.2s;
  text-transform: uppercase;
}
.ciclo-btn:hover, .ciclo-btn.active {
  background: rgba(0,180,255,0.15);
  border-color: var(--accent);
  color: var(--accent);
}

/* ── CRISI IDRICA ── */
.crisis-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

@media (max-width: 600px) { .crisis-grid { grid-template-columns: 1fr; } }

.crisis-card {
  border-radius: 14px;
  padding: 1.8rem;
  border: 1px solid var(--border);
}

.crisis-card.red { background: rgba(255,78,80,0.07); border-color: rgba(255,78,80,0.2); }
.crisis-card.blue { background: rgba(0,180,255,0.05); border-color: rgba(0,180,255,0.15); }
.crisis-card.green { background: rgba(0,229,192,0.05); border-color: rgba(0,229,192,0.15); }
.crisis-card.yellow { background: rgba(255,200,0,0.05); border-color: rgba(255,200,0,0.15); }

.crisis-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 3.5rem;
  line-height: 1;
  margin-bottom: 0.3rem;
}

.red .crisis-num { color: var(--danger); }
.blue .crisis-num { color: var(--accent); }
.green .crisis-num { color: var(--accent2); }
.yellow .crisis-num { color: #ffc800; }

.crisis-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }

/* ── MOLECOLA H2O ── */
.molecule-section {
  background: var(--surface);
  padding: 5rem 2rem;
}

.h2o-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  max-width: 1100px;
  margin: 0 auto;
}

@media (max-width: 700px) { .h2o-grid { grid-template-columns: 1fr; } }

.h2o-visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

svg.h2o { width: 260px; height: 260px; }

.h2o-facts { display: flex; flex-direction: column; gap: 1rem; }

.fact-row {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  padding: 1rem;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: var(--card);
}

.fact-key {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem;
  color: var(--accent);
  width: 100px;
  flex-shrink: 0;
  padding-top: 2px;
}

.fact-val { font-size: 0.88rem; color: var(--text); line-height: 1.5; }

/* ── FOOTER ── */
footer {
  text-align: center;
  padding: 2rem;
  font-size: 0.75rem;
  color: var(--muted);
  border-top: 1px solid var(--border);
}
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="water-grid"></div>
  <div class="molecule"></div>
  <div class="molecule"></div>
  <div class="molecule"></div>

  <div class="hero-label">Scienza — Primo Biennio</div>
  <h1>L'IMPORTANZA<span>DELL'ACQUA</span></h1>
  <p class="hero-sub">La molecola più abbondante sulla Terra e fondamento di ogni forma di vita conosciuta. Senza acqua, la vita come la conosciamo non esisterebbe.</p>

  <div class="hero-stats">
    <div class="hero-stat">
      <div class="num">71%</div>
      <div class="unit">della superficie terrestre</div>
    </div>
    <div class="hero-stat">
      <div class="num">60%</div>
      <div class="unit">del corpo umano</div>
    </div>
    <div class="hero-stat">
      <div class="num">2,5%</div>
      <div class="unit">acqua dolce disponibile</div>
    </div>
    <div class="hero-stat">
      <div class="num">8,3M</div>
      <div class="unit">specie dipendenti</div>
    </div>
  </div>
</section>

<hr class="divider">

<!-- FUNZIONI -->
<section class="section">
  <div class="section-tag">// Funzioni biologiche</div>
  <div class="section-title">PERCHÉ L'ACQUA È ESSENZIALE</div>
  <div class="cards-grid">
    <div class="card">
      <div class="card-icon">🧬</div>
      <div class="card-title">Solvente universale</div>
      <div class="card-text">Scioglie sali minerali, glucosio e gas, permettendo le reazioni chimiche cellulari essenziali alla vita.</div>
    </div>
    <div class="card">
      <div class="card-icon">🌡️</div>
      <div class="card-title">Termoregolazione</div>
      <div class="card-text">L'alta capacità termica dell'acqua stabilizza la temperatura corporea e quella del pianeta.</div>
    </div>
    <div class="card">
      <div class="card-icon">🔄</div>
      <div class="card-title">Trasporto nutrienti</div>
      <div class="card-text">Veicola ossigeno, ormoni e sostanze nutritive attraverso il sangue e la linfa verso ogni cellula.</div>
    </div>
    <div class="card">
      <div class="card-icon">⚗️</div>
      <div class="card-title">Reazioni metaboliche</div>
      <div class="card-text">Partecipa direttamente a idrolisi, fotosintesi e respirazione cellulare come reagente.</div>
    </div>
    <div class="card">
      <div class="card-icon">🛡️</div>
      <div class="card-title">Protezione organi</div>
      <div class="card-text">Il liquido amniotico, il liquido cerebrospinale e le articolazioni usano l'acqua come ammortizzatore.</div>
    </div>
    <div class="card">
      <div class="card-icon">🌿</div>
      <div class="card-title">Fotosintesi</div>
      <div class="card-text">Le piante scindono H₂O per liberare ossigeno e produrre glucosio tramite l'energia solare.</div>
    </div>
  </div>
</section>

<hr class="divider">

<!-- DISTRIBUZIONE -->
<section class="chart-section">
  <div class="chart-inner">
    <div class="section-tag">// Distribuzione idrica globale</div>
    <div class="section-title">DOVE SI TROVA L'ACQUA</div>
    <div class="bar-chart" id="barChart">
      <div class="bar-row">
        <div class="bar-label">Oceani e mari</div>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width:97.5%; background: linear-gradient(90deg,#003580,#0066ff); color:#fff;" data-info="Coprono il 71% della superficie terrestre">97,5%</div>
          <div class="bar-tooltip">🌊 Volume: ~1,335 mld km³ · Salinità media: 3,5%</div>
        </div>
        <div class="bar-val">salata</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Ghiacciai polari</div>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width:69%; background: linear-gradient(90deg,#005c8a,#00b4ff); color:#fff;">1,72%</div>
          <div class="bar-tooltip">🧊 Contengono il 69% di tutta l'acqua dolce</div>
        </div>
        <div class="bar-val">dolce</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Acque sotterranee</div>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width:31%; background: linear-gradient(90deg,#006655,#00e5c0); color:#000;">0,76%</div>
          <div class="bar-tooltip">🪨 Risorsa primaria per 2 miliardi di persone</div>
        </div>
        <div class="bar-val">dolce</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Laghi e fiumi</div>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width:4%; min-width:65px; background: linear-gradient(90deg,#007755,#44ffcc); color:#000;">0,01%</div>
          <div class="bar-tooltip">💧 Fonte principale di acqua potabile accessibile</div>
        </div>
        <div class="bar-val">dolce</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Atmosfera</div>
        <div class="bar-track">
          <div class="bar-fill" style="--target-width:2%; min-width:55px; background: linear-gradient(90deg,#445566,#99bbcc); color:#fff;">0,001%</div>
          <div class="bar-tooltip">☁️ Nuvole, vapore e precipitazioni · Ciclo ogni 9 giorni</div>
        </div>
        <div class="bar-val">vapore</div>
      </div>
    </div>
    <p style="font-size:0.78rem; color:var(--muted); margin-top:1.2rem; font-family:'IBM Plex Mono',monospace;">Fonte: USGS — United States Geological Survey · Passa il mouse sulle barre per i dettagli</p>
  </div>
</section>

<hr class="divider">

<!-- CICLO DELL'ACQUA -->
<section class="ciclo-section">
  <div class="ciclo-inner">
    <div class="section-tag">// Simulatore interattivo</div>
    <div class="section-title">IL CICLO DELL'ACQUA</div>
    <div class="ciclo-canvas">
      <canvas id="cicloCanvas"></canvas>
    </div>
    <div class="ciclo-steps">
      <button class="ciclo-btn active" onclick="setCiclo('all')">▶ Tutto il ciclo</button>
      <button class="ciclo-btn" onclick="setCiclo('evaporazione')">☀ Evaporazione</button>
      <button class="ciclo-btn" onclick="setCiclo('condensazione')">☁ Condensazione</button>
      <button class="ciclo-btn" onclick="setCiclo('precipitazione')">🌧 Precipitazione</button>
      <button class="ciclo-btn" onclick="setCiclo('scorrimento')">🌊 Scorrimento</button>
    </div>
  </div>
</section>

<hr class="divider">

<!-- CRISI IDRICA -->
<section class="section">
  <div class="section-tag">// Crisi idrica globale</div>
  <div class="section-title">I NUMERI DELL'EMERGENZA</div>
  <div class="crisis-grid">
    <div class="crisis-card red">
      <div class="crisis-num">2,2 MLD</div>
      <div class="crisis-desc">Persone nel mondo prive di accesso ad acqua potabile sicura (ONU, 2023).</div>
    </div>
    <div class="crisis-card blue">
      <div class="crisis-num">4 MLD</div>
      <div class="crisis-desc">Persone che vivono una grave carenza d'acqua almeno un mese all'anno.</div>
    </div>
    <div class="crisis-card yellow">
      <div class="crisis-num">70%</div>
      <div class="crisis-desc">Dell'acqua dolce consumata a livello mondiale è usata dall'agricoltura per irrigazione.</div>
    </div>
    <div class="crisis-card green">
      <div class="crisis-num">+40%</div>
      <div class="crisis-desc">Aumento previsto della domanda idrica globale entro il 2050 a causa di popolazione e clima.</div>
    </div>
  </div>
</section>

<hr class="divider">

<!-- MOLECOLA H2O -->
<section class="molecule-section">
  <div class="h2o-grid">
    <div class="h2o-visual">
      <svg class="h2o" viewBox="0 0 260 260" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- bonds -->
        <line x1="130" y1="130" x2="72" y2="190" stroke="#00b4ff" stroke-width="6" stroke-linecap="round" opacity="0.6"/>
        <line x1="130" y1="130" x2="188" y2="190" stroke="#00b4ff" stroke-width="6" stroke-linecap="round" opacity="0.6"/>
        <!-- electron pairs (lone) -->
        <circle cx="115" cy="95" r="5" fill="#00e5c0" opacity="0.5"/>
        <circle cx="100" cy="108" r="5" fill="#00e5c0" opacity="0.5"/>
        <circle cx="145" cy="95" r="5" fill="#00e5c0" opacity="0.5"/>
        <circle cx="160" cy="108" r="5" fill="#00e5c0" opacity="0.5"/>
        <!-- O atom -->
        <circle cx="130" cy="130" r="36" fill="#061828" stroke="#00b4ff" stroke-width="2.5"/>
        <text x="130" y="137" text-anchor="middle" font-family="Bebas Neue,sans-serif" font-size="26" fill="#00b4ff">O</text>
        <!-- H atoms -->
        <circle cx="68" cy="196" r="24" fill="#061828" stroke="#00e5c0" stroke-width="2"/>
        <text x="68" y="203" text-anchor="middle" font-family="Bebas Neue,sans-serif" font-size="22" fill="#00e5c0">H</text>
        <circle cx="192" cy="196" r="24" fill="#061828" stroke="#00e5c0" stroke-width="2"/>
        <text x="192" y="203" text-anchor="middle" font-family="Bebas Neue,sans-serif" font-size="22" fill="#00e5c0">H</text>
        <!-- angle label -->
        <path d="M 88 175 A 40 40 0 0 1 172 175" stroke="#ffc800" stroke-width="1.5" fill="none" stroke-dasharray="4,3"/>
        <text x="130" y="170" text-anchor="middle" font-family="IBM Plex Mono,monospace" font-size="11" fill="#ffc800">104.5°</text>
        <!-- delta charges -->
        <text x="130" y="90" text-anchor="middle" font-size="13" fill="#ff4e50" font-family="IBM Plex Mono,monospace">δ−</text>
        <text x="50" y="218" text-anchor="middle" font-size="11" fill="#aaa" font-family="IBM Plex Mono,monospace">δ+</text>
        <text x="210" y="218" text-anchor="middle" font-size="11" fill="#aaa" font-family="IBM Plex Mono,monospace">δ+</text>
      </svg>
    </div>

    <div>
      <div class="section-tag">// Proprietà chimiche</div>
      <div class="section-title" style="font-size:2.2rem; margin-bottom:1.5rem;">LA MOLECOLA H₂O</div>
      <div class="h2o-facts">
        <div class="fact-row">
          <div class="fact-key">FORMULA</div>
          <div class="fact-val">H₂O — 2 idrogeni legati a 1 ossigeno con geometria angolare</div>
        </div>
        <div class="fact-row">
          <div class="fact-key">ANGOLO</div>
          <div class="fact-val">104,5° tra i legami H–O–H, dovuto alle coppie solitarie dell'ossigeno</div>
        </div>
        <div class="fact-row">
          <div class="fact-key">POLARITÀ</div>
          <div class="fact-val">Molecola polare: l'ossigeno attrae più elettroni (δ−), gli idrogeni restano δ+</div>
        </div>
        <div class="fact-row">
          <div class="fact-key">LEGAMI H</div>
          <div class="fact-val">Forma legami idrogeno tra molecole → alta tensione superficiale e capillarità</div>
        </div>
        <div class="fact-row">
          <div class="fact-key">DENSITÀ</div>
          <div class="fact-val">Il ghiaccio galleggia sull'acqua liquida: anomalia che protegge la vita acquatica</div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer>
  Elaborazione scientifica — Primo Biennio Superiori &nbsp;·&nbsp; Fonti: ONU, USGS, WHO, FAO
</footer>

<script>
// ── BAR CHART ANIMATION ON SCROLL ──
const fills = document.querySelectorAll('.bar-fill');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.bar-fill').forEach(f => f.classList.add('animated'));
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
document.querySelectorAll('.bar-chart').forEach(c => observer.observe(c));

// ── WATER CYCLE SIMULATOR ──
const canvas = document.getElementById('cicloCanvas');
const ctx = canvas.getContext('2d');
let W, H, animFrame;
let activePhase = 'all';
let particles = [];
let clouds = [];
let t = 0;

function resize() {
  const rect = canvas.parentElement.getBoundingClientRect();
  W = canvas.width = rect.width;
  H = canvas.height = rect.height;
  initScene();
}

function initScene() {
  particles = [];
  clouds = [
    { x: W * 0.35, y: H * 0.15, w: 100, speed: 0.12 },
    { x: W * 0.65, y: H * 0.1, w: 75, speed: 0.08 },
  ];
}

function spawnParticle(phase) {
  if (phase === 'evaporazione' || phase === 'all') {
    if (Math.random() < 0.12) {
      particles.push({
        type: 'vapor',
        x: W * 0.15 + Math.random() * W * 0.55,
        y: H * 0.72,
        vx: (Math.random() - 0.5) * 0.4,
        vy: -(0.5 + Math.random() * 0.8),
        life: 1, alpha: 0.7, r: 2 + Math.random() * 2
      });
    }
  }
  if (phase === 'precipitazione' || phase === 'all') {
    if (Math.random() < 0.15) {
      particles.push({
        type: 'rain',
        x: W * 0.2 + Math.random() * W * 0.6,
        y: H * 0.22,
        vx: 0.3,
        vy: 3 + Math.random() * 2,
        life: 1, alpha: 0.8, r: 1.5
      });
    }
  }
  if (phase === 'scorrimento' || phase === 'all') {
    if (Math.random() < 0.08) {
      particles.push({
        type: 'river',
        x: W * 0.08,
        y: H * 0.62 + Math.random() * 8,
        vx: 1.2 + Math.random() * 0.5,
        vy: 0.2,
        life: 1, alpha: 0.9, r: 2
      });
    }
  }
}

function drawScene() {
  // Sky gradient
  const sky = ctx.createLinearGradient(0, 0, 0, H);
  sky.addColorStop(0, '#020d18');
  sky.addColorStop(0.5, '#041525');
  sky.addColorStop(1, '#061e35');
  ctx.fillStyle = sky;
  ctx.fillRect(0, 0, W, H);

  // Sun
  if (activePhase === 'evaporazione' || activePhase === 'all') {
    const sunX = W * 0.88, sunY = H * 0.12;
    const sunGlow = ctx.createRadialGradient(sunX, sunY, 0, sunX, sunY, 60);
    sunGlow.addColorStop(0, 'rgba(255,200,50,0.35)');
    sunGlow.addColorStop(1, 'transparent');
    ctx.fillStyle = sunGlow;
    ctx.beginPath(); ctx.arc(sunX, sunY, 60, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = '#ffd54f';
    ctx.beginPath(); ctx.arc(sunX, sunY, 18, 0, Math.PI * 2); ctx.fill();
    // Sun rays
    ctx.strokeStyle = 'rgba(255,213,79,0.3)';
    ctx.lineWidth = 1.5;
    for (let i = 0; i < 8; i++) {
      const a = (i / 8) * Math.PI * 2 + t * 0.005;
      ctx.beginPath();
      ctx.moveTo(sunX + Math.cos(a) * 24, sunY + Math.sin(a) * 24);
      ctx.lineTo(sunX + Math.cos(a) * 38, sunY + Math.sin(a) * 38);
      ctx.stroke();
    }
  }

  // Mountains
  ctx.fillStyle = '#0a1e35';
  ctx.beginPath();
  ctx.moveTo(0, H * 0.75);
  ctx.lineTo(W * 0.12, H * 0.42);
  ctx.lineTo(W * 0.22, H * 0.55);
  ctx.lineTo(W * 0.32, H * 0.38);
  ctx.lineTo(W * 0.42, H * 0.52);
  ctx.lineTo(W, H * 0.52);
  ctx.lineTo(W, H); ctx.lineTo(0, H);
  ctx.closePath(); ctx.fill();

  // Snow cap
  ctx.fillStyle = 'rgba(200,230,255,0.7)';
  ctx.beginPath();
  ctx.moveTo(W * 0.32, H * 0.38);
  ctx.lineTo(W * 0.28, H * 0.46);
  ctx.lineTo(W * 0.36, H * 0.46);
  ctx.closePath(); ctx.fill();

  // Ocean / lake
  const waterGrad = ctx.createLinearGradient(0, H * 0.72, 0, H);
  waterGrad.addColorStop(0, '#003d7a');
  waterGrad.addColorStop(1, '#001a3a');
  ctx.fillStyle = waterGrad;
  ctx.beginPath();
  ctx.moveTo(0, H * 0.72);
  for (let x = 0; x <= W; x += 8) {
    const wave = Math.sin(x * 0.02 + t * 0.03) * 4;
    ctx.lineTo(x, H * 0.72 + wave);
  }
  ctx.lineTo(W, H); ctx.lineTo(0, H);
  ctx.closePath(); ctx.fill();

  // River
  if (activePhase === 'scorrimento' || activePhase === 'all') {
    ctx.strokeStyle = 'rgba(0,150,255,0.5)';
    ctx.lineWidth = 8;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(W * 0.32, H * 0.46);
    ctx.bezierCurveTo(W * 0.25, H * 0.6, W * 0.15, H * 0.65, W * 0.08, H * 0.72);
    ctx.stroke();
  }

  // Clouds
  if (activePhase === 'condensazione' || activePhase === 'precipitazione' || activePhase === 'all') {
    clouds.forEach(cloud => {
      cloud.x += cloud.speed;
      if (cloud.x > W + 100) cloud.x = -100;
      drawCloud(cloud.x, cloud.y, cloud.w);
    });
  }

  // Labels
  ctx.font = '600 11px IBM Plex Mono, monospace';
  ctx.textAlign = 'center';
  if (activePhase === 'evaporazione' || activePhase === 'all') {
    ctx.fillStyle = 'rgba(255,180,50,0.8)';
    ctx.fillText('EVAPORAZIONE', W * 0.5, H * 0.68);
  }
  if (activePhase === 'condensazione' || activePhase === 'all') {
    ctx.fillStyle = 'rgba(150,200,255,0.8)';
    ctx.fillText('CONDENSAZIONE', W * 0.38, H * 0.08);
  }
  if (activePhase === 'precipitazione' || activePhase === 'all') {
    ctx.fillStyle = 'rgba(80,160,255,0.8)';
    ctx.fillText('PRECIPITAZIONE', W * 0.65, H * 0.32);
  }
  if (activePhase === 'scorrimento' || activePhase === 'all') {
    ctx.fillStyle = 'rgba(0,200,220,0.8)';
    ctx.fillText('SCORRIMENTO', W * 0.18, H * 0.58);
  }

  // Particles
  spawnParticle(activePhase);
  particles = particles.filter(p => p.life > 0);
  particles.forEach(p => {
    p.x += p.vx; p.y += p.vy;
    if (p.type === 'vapor') {
      p.vy *= 0.995;
      p.life -= 0.004;
      p.alpha = p.life * 0.7;
      ctx.fillStyle = `rgba(180,220,255,${p.alpha})`;
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
      if (p.y < H * 0.25) p.life = 0;
    }
    if (p.type === 'rain') {
      ctx.strokeStyle = `rgba(100,180,255,${p.alpha})`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(p.x, p.y);
      ctx.lineTo(p.x - 2, p.y + 8);
      ctx.stroke();
      if (p.y > H * 0.72) p.life = 0;
      else p.life -= 0.005;
    }
    if (p.type === 'river') {
      ctx.fillStyle = `rgba(0,180,255,${p.alpha})`;
      ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
      if (p.x > W * 0.2 || p.y > H * 0.73) p.life = 0;
      else p.life -= 0.006;
    }
  });

  t++;
  animFrame = requestAnimationFrame(drawScene);
}

function drawCloud(x, y, w) {
  ctx.fillStyle = 'rgba(160,200,240,0.2)';
  ctx.beginPath();
  ctx.arc(x, y, w * 0.35, 0, Math.PI * 2);
  ctx.arc(x + w * 0.28, y - w * 0.1, w * 0.28, 0, Math.PI * 2);
  ctx.arc(x + w * 0.55, y, w * 0.28, 0, Math.PI * 2);
  ctx.arc(x + w * 0.25, y + w * 0.12, w * 0.25, 0, Math.PI * 2);
  ctx.fill();
}

function setCiclo(phase) {
  activePhase = phase;
  particles = [];
  document.querySelectorAll('.ciclo-btn').forEach(b => {
    b.classList.toggle('active', b.getAttribute('onclick').includes(`'${phase}'`));
  });
}

window.setCiclo = setCiclo;
window.addEventListener('resize', () => { cancelAnimationFrame(animFrame); resize(); drawScene(); });
resize();
drawScene();
</script>
</body>
</html>
